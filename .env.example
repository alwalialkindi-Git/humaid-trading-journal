# Supabase — create a project at https://supabase.com, then copy these from
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------------------------
# Market data (server-side only — none of these are NEXT_PUBLIC_*)
# ---------------------------------------------------------------------------

# Active provider: yahoo (default, free, keyless) | twelvedata | eodhd | mock
# Unknown values fall back to mock (deterministic fixtures, no network).
MARKET_DATA_PROVIDER=yahoo

# Twelve Data — REQUIRED only when MARKET_DATA_PROVIDER=twelvedata.
# Get a key at https://twelvedata.com. Provider stub:
# src/lib/market-data/providers/twelvedata.ts (see file header to implement).
# TWELVE_DATA_API_KEY=

# EODHD — REQUIRED only when MARKET_DATA_PROVIDER=eodhd.
# Get a token at https://eodhd.com. Candidate for ADX coverage in M2.
# Provider stub: src/lib/market-data/providers/eodhd.ts.
# EODHD_API_TOKEN=
